{
  "name": "thunder-subtitle-downloader",
  "version": "0.1.0",
  "description": "ThunderSub - 迅雷影音智能字幕下载工具",
  "author": {
    "name": "lichen",
    "email": "f360family@gmail.com"
  },
  "packageManager": "pnpm@9.15.0",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev --watch",
    "build": "electron-vite build",
    "dist": "pnpm run build && electron-builder --win",
    "dist:mac": "pnpm run build && electron-builder --mac",
    "dist:linux": "pnpm run build && electron-builder --linux",
    "dist:all": "pnpm run build && electron-builder --win --mac --linux",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "dependencies": {
    "electron-store": "^10.0.1",
    "electron-updater": "^6.8.9",
    "p-limit": "^6.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.16.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.36.0",
    "@typescript-eslint/parser": "^8.36.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "prettier": "^3.6.2",
    "sharp": "^0.35.1",
    "typescript": "^5.8.3",
    "vite": "^5.4.19"
  },
  "build": {
    "appId": "com.lichen.thundersub",
    "productName": "ThunderSub",
    "copyright": "Copyright © 2024 lichen",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asar": true,
    "icon": "assets/icon.png",
    "publish": {
      "provider": "github",
      "owner": "lichen",
      "repo": "thunderSub",
      "releaseType": "draft"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "license": null,
      "runAfterFinish": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ThunderSub",
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "include": "build/installer.nsh",
      "menuCategory": false,
      "deleteAppDataOnUninstall": true,
      "displayLanguageSelector": false
    },
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "category": "public.app-category.video",
      "icon": "assets/icon.png"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "category": "Video",
      "icon": "assets/icon.png"
    }
  }
}
